# Google Generative AI (Gemini) API key used by the /chat feature.
# Generate one at: https://aistudio.google.com/app/apikey
# Do NOT prefix with VITE_ — this key is only read server-side by api/chat.js
# and must never be shipped in the client bundle.
GOOGLE_GENERATIVE_AI_API_KEY=

# Supermemory API key — enables long-context memory on /chat (profile + recall).
# Generate / rotate at https://app.supermemory.ai.
# Server-side only; if unset, chat still works but without any memory injection.
SUPERMEMORY_API_KEY=
